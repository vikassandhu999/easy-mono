#!/bin/sh
set -eu

cd -P -- "$(dirname -- "$0")"

# Set memory-constrained Erlang VM flags for small VMs
export ERL_FLAGS="+P 16384 +Q 4096 +e 1024 +t 500000 +S 1:1 +SDcpu 1:1 +sbwt none +sbwtdcpu none +sbwtdio none +A 4 +MBas aobf +MHas aobf +MBsmbcs 128 +MBlmbcs 256 +MHsmbcs 128 +MHlmbcs 256"
export ERL_MAX_PORTS="4096"

exec ./easy eval Easy.Release.migrate
