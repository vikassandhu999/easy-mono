# =============================================================================
# Easy Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# PostgreSQL Database
POSTGRES_USER=easy
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=easy_prod

# Phoenix Application
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here_min_64_chars

# JWT Secret (min 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Host configuration
PHX_HOST=yourdomain.com

# Database pool size (reduce for small VMs, 5 is good for 1GB)
POOL_SIZE=5

# =============================================================================
# Email Configuration
# =============================================================================
MAILER_ADAPTER=postmark

# Postmark
POSTMARK_API_KEY=your_postmark_api_key

# SendGrid (if using sendgrid adapter)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Mailgun (if using mailgun adapter)
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=your_mailgun_domain

# SMTP (if using smtp adapter)
# SMTP_RELAY=smtp.example.com
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
# SMTP_PORT=587

# =============================================================================
# Frontend URLs
# =============================================================================
APP_URL=https://yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CLIENT_FRONTEND_URL=https://client.yourdomain.com

# Email sender
EMAIL_FROM_NAME=Easy Coaching
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
