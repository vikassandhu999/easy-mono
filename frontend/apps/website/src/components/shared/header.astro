---
import Logo from "../../assets/logos/logo.png";
import { APP_CONFIG } from "../../lib/env";
---

<header
  class="container p-4 flex justify-between items-center mx-auto relative"
>
  <a
    href="/"
    aria-label={`${APP_CONFIG.title} Home`}
    class="flex items-center gap-2"
  >
    <img src={Logo.src} alt={`${APP_CONFIG.title} logo`} class="h-8" />
  </a>

  <!-- Desktop Nav -->
  <nav
    class="hidden md:flex items-center gap-6 text-sm font-medium text-[#1b2947]"
  >
    <a
      href="/privacy-policy"
      class="text-lg hover:opacity-70 transition-opacity">Privacy Policy</a
    >
    <a
      href="/terms-of-service"
      class="text-lg hover:opacity-70 transition-opacity">Terms of Service</a
    >
  </nav>

  <!-- Mobile Menu Button -->
  <button
    id="menu-btn"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-nav"
    class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg border border-[#1b2947]/15 bg-white/80 backdrop-blur-sm shadow-sm active:scale-95 transition"
    type="button"
  >
    <span class="sr-only">Toggle navigation</span>
    <svg
      id="menu-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      stroke="#1b2947"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    >
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <!-- Mobile Nav Panel -->
  <div
    id="mobile-nav"
    class="md:hidden hidden absolute top-full right-0 mt-2 w-56 rounded-xl border border-[#1b2947]/10 bg-white/95 backdrop-blur-md shadow-lg py-4 px-4 flex flex-col gap-3 text-sm font-medium text-[#1b2947]"
  >
    <a href="/privacy-policy" class="hover:opacity-70 transition-opacity"
      >Privacy Policy</a
    >
    <a href="/terms-of-service" class="hover:opacity-70 transition-opacity"
      >Terms of Service</a
    >
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const panel = document.getElementById("mobile-nav");
  if (btn && panel) {
    btn.addEventListener("click", () => {
      const isHidden = panel.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", (!isHidden).toString());
    });
    // Close when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!panel.classList.contains("hidden")) {
        if (!panel.contains(target) && !btn.contains(target)) {
          panel.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        }
      }
    });
    // Close on ESC
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !panel.classList.contains("hidden")) {
        panel.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
