# App Configuration
VITE_APP_TITLE=CoachEasy
VITE_APP_DESCRIPTION=Professional coaching platform for managing clients, programs, and sessions
VITE_APP_URL=https://coacheasy.com
VITE_API_BASE_URL=https://api.coacheasy.com

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# Contact Information
VITE_CONTACT_EMAIL=kaizen.tech404@gmail.com
VITE_SUPPORT_EMAIL=kaizen.tech404@gmail.com

# Development
NODE_ENV=development
