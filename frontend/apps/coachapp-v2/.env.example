# API base URL the coach app calls. REQUIRED for any non-local (deployed) build —
# Vite inlines this at BUILD time, so it must be set in the Vercel project env
# (Production + Preview), not just at runtime. Falls back to http://localhost:4000 in dev.
VITE_API_BASE_URL=https://easy-backend.fly.dev

# Public website origin that serves coach landing pages (used by the landing-page
# editor's "Preview" / public URL). Defaults to http://localhost:3000 in dev.
VITE_PUBLIC_SITE_URL=https://coacheasy.app
