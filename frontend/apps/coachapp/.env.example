# ===========================================
# CoachEasy Environment Configuration
# ===========================================
# Copy this file to .env.local for local development
# or .env.production.local for production builds
#
# Vite automatically loads:
# - .env                 (always loaded)
# - .env.local           (always loaded, ignored by git)
# - .env.[mode]          (only in specified mode)
# - .env.[mode].local    (only in specified mode, ignored by git)
#
# Priority (highest to lowest):
# .env.[mode].local > .env.[mode] > .env.local > .env
# ===========================================

# ===========================================
# API Configuration
# ===========================================

# Backend API Base URL
# Development: Usually http://localhost:4000 or http://localhost:8080
# Production: Your production API URL (e.g., https://api.coacheasy.com)
VITE_API_BASE_URL=http://localhost:4000

# ===========================================
# Feature Flags (Optional)
# ===========================================

# Enable verbose logging in production (default: false)
# Set to "true" to enable debug logs in production builds
VITE_ENABLE_DEBUG_LOGS=false

# ===========================================
# Analytics & Error Tracking (Optional)
# ===========================================

# Sentry DSN for error tracking
# Get this from your Sentry project settings
# VITE_SENTRY_DSN=

# Google Analytics Measurement ID
# VITE_GA_MEASUREMENT_ID=

# ===========================================
# PWA Configuration (Optional)
# ===========================================

# App name displayed in PWA install prompts
VITE_APP_NAME=CoachEasy

# App short name for home screen
VITE_APP_SHORT_NAME=CoachEasy

# ===========================================
# Notes
# ===========================================
#
# 1. All environment variables must be prefixed with VITE_
#    to be exposed to the client-side code
#
# 2. Never commit sensitive values (API keys, secrets) to git
#    Use .env.local or .env.production.local for secrets
#
# 3. Access variables in code via: import.meta.env.VITE_VARIABLE_NAME
#
# 4. Changes to .env files require a dev server restart
